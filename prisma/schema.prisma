// ==================== AETHER POS SCHEMA ====================
// Uses DATABASE_URL — works with SQLite (local) or PostgreSQL (Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== OUTLET ====================
model Outlet {
  id           String   @id @default(cuid())
  name         String
  address      String?
  phone        String?
  accountType  String   @default("free") // free, pro, enterprise
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users           User[]
  products        Product[]
  customers       Customer[]
  categories      Category[]
  transactions    Transaction[]
  auditLogs       AuditLog[]
  setting         OutletSetting?
  promos          Promo[]
  crewPermissions CrewPermission[]
}

// ==================== USER ====================
model User {
  id            String   @id @default(cuid())
  name          String
  email         String
  password      String
  role          String   @default("CREW") // OWNER or CREW
  outletId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outlet          Outlet           @relation(fields: [outletId], references: [id])
  transactions    Transaction[]
  auditLogs       AuditLog[]
  crewPermission  CrewPermission?

  @@unique([email, outletId])
}

// ==================== CATEGORY ====================
model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("zinc")  // Tailwind color name for chip styling
  outletId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet   Outlet     @relation(fields: [outletId], references: [id])
  products Product[]

  @@unique([name, outletId])
}

// ==================== PRODUCT ====================
model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String?
  barcode       String?
  hpp           Float    @default(0)    // Harga Pokok Produksi (Cost Price)
  price         Float                    // Selling Price
  bruto         Float    @default(0)    // Gross weight
  netto         Float    @default(0)    // Net weight
  stock         Int      @default(0)    // Current stock
  lowStockAlert Int      @default(10)   // Alert threshold
  image         String?                 // Snapshot image URL
  categoryId    String?
  outletId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  outlet           Outlet         @relation(fields: [outletId], references: [id])
  category        Category?      @relation(fields: [categoryId], references: [id])
  transactionItems TransactionItem[]
  auditLogs        AuditLog[]

  @@unique([name, outletId])
}

// ==================== CUSTOMER ====================
model Customer {
  id          String   @id @default(cuid())
  name        String
  whatsapp    String   @unique     // WhatsApp number as unique ID
  totalSpend  Float    @default(0) // Running total
  points      Int      @default(0) // Current loyalty points
  outletId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet       Outlet       @relation(fields: [outletId], references: [id])
  transactions Transaction[]
  loyaltyLogs  LoyaltyLog[]
}

// ==================== TRANSACTION ====================
model Transaction {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  subtotal      Float
  discount      Float    @default(0)
  pointsUsed    Int      @default(0)
  total         Float
  paymentMethod String               // CASH, QRIS, DEBIT
  paidAmount    Float    @default(0)
  change        Float    @default(0)
  note          String?
  outletId      String
  customerId    String?
  userId        String
  createdAt     DateTime @default(now())

  outlet           Outlet            @relation(fields: [outletId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  user             User              @relation(fields: [userId], references: [id])
  items            TransactionItem[]
  loyaltyLogs      LoyaltyLog[]
}

// ==================== TRANSACTION ITEM ====================
model TransactionItem {
  id             String      @id @default(cuid())
  productId      String
  productName    String
  price          Float
  qty            Int
  subtotal       Float
  hpp            Float
  transactionId  String

  product     Product     @relation(fields: [productId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

// ==================== LOYALTY LOG ====================
model LoyaltyLog {
  id             String    @id @default(cuid())
  type           String              // EARN or REDEEM
  points         Int                 // positive for earn, negative for redeem
  description    String
  customerId     String
  transactionId  String?
  createdAt      DateTime @default(now())

  customer    Customer    @relation(fields: [customerId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id])
}

// ==================== AUDIT LOG ====================
model AuditLog {
  id          String   @id @default(cuid())
  action      String               // CREATE, RESTOCK, SALE, ADJUSTMENT
  entityType  String               // PRODUCT, STOCK
  entityId    String?
  details     String?              // JSON string with change details
  outletId    String
  userId      String
  createdAt   DateTime @default(now())

  outlet  Outlet  @relation(fields: [outletId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [entityId], references: [id])
}

// ==================== OUTLET SETTING ====================
model OutletSetting {
  id      String @id @default(cuid())
  outletId String @unique

  // Payment methods: comma-separated enabled methods
  paymentMethods String @default("CASH,QRIS")

  // Loyalty program config
  loyaltyEnabled          Boolean @default(true)
  loyaltyPointsPerAmount  Int     @default(10000) // 1 point per Rp10,000 spent
  loyaltyPointValue       Int     @default(100)   // 1 point = Rp100 discount

  // Receipt config
  receiptBusinessName String @default("Aether POS")
  receiptAddress      String @default("")
  receiptPhone        String @default("")
  receiptFooter       String @default("Terima kasih atas kunjungan Anda!")
  receiptLogo         String @default("")

  // Theme
  themePrimaryColor String @default("emerald") // tailwind color name: emerald, blue, violet, rose, amber

  // Telegram notifications
  telegramChatId   String?                // Owner's Telegram chat ID for notifications
  notifyOnTransaction Boolean @default(true) // Notify on every new transaction
  notifyOnCustomer   Boolean @default(true) // Notify on new customer registration
  notifyDailyReport  Boolean @default(true) // Daily revenue summary
  notifyWeeklyReport Boolean @default(false) // Weekly report
  notifyMonthlyReport Boolean @default(true) // Monthly report

  outlet    Outlet   @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== PROMO ====================
model Promo {
  id          String   @id @default(cuid())
  name        String
  type        String               // "PERCENTAGE" or "NOMINAL"
  value       Float                // percentage (e.g. 10) or nominal (e.g. 50000)
  minPurchase Float?               // minimum purchase amount to apply
  maxDiscount Float?               // max discount cap for percentage type
  active      Boolean  @default(true)
  outletId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  outlet Outlet @relation(fields: [outletId], references: [id])
}

// ==================== CREW PERMISSION ====================
model CrewPermission {
  id       String @id @default(cuid())
  userId   String @unique
  // Comma-separated allowed pages for this crew member
  pages    String @default("pos")
  outletId String

  user   User   @relation(fields: [userId], references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
